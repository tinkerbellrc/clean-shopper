# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and will never be committed.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic API key for the AI chat feature.
# Get yours at https://console.anthropic.com
# Note: this key is exposed to the browser — fine for prototyping,
# but use a backend proxy before going to production.
VITE_ANTHROPIC_API_KEY=your-anthropic-key-here
